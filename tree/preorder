class Solution {
public:
void preOrder(vector<int>& v ,TreeNode* root) {
    if(root == NULL) {
        return;
    }
    v.push_back(root->val);
    preOrder(v,root->left);
    preOrder(v,root->right);
    return;
}
    vector<int> preorderTraversal(TreeNode* root) {
        vector<int> ans;
        preOrder(ans,root);
        return ans;
    }
};
