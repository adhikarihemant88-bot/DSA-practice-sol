class Solution {
public:
    int ans = INT_MIN;

    int maxPath(TreeNode* root) {
        if (!root) return 0;
        int left = max(0, maxPath(root->left));
        int right = max(0, maxPath(root->right));
        ans = max(ans, root->val + left + right);
        return root->val + max(left, right);
    }

    int maxPathSum(TreeNode* root) {
        maxPath(root);
        return ans;
    }
};
