class Solution {
public:
int diameter(TreeNode* root,int & ans) {
        if(root == NULL) {
            return 0;
        }
        int left = diameter(root->left,ans);
        int right = diameter(root->right,ans);
        if(left+right >ans){
            ans = left+right;
        }
        return 1+max(left,right);
}
    int diameterOfBinaryTree(TreeNode* root) {
        int ans = INT_MIN;
        int h = diameter(root,ans);
        return ans;
    }
};
