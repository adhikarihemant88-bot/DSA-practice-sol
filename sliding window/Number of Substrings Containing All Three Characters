class Solution {
public:
    int numberOfSubstrings(string s) {
        map<char,int> mp; int ans =0;
        mp['a'] =-1;
        mp['b'] = -1;
        mp['c'] = -1;
        for(int i=0;i<s.size();i++) {
            mp[s[i]] = i;
            if(mp['a'] != -1 && mp['b'] != -1 && mp['c'] != -1) {
                int val = min(mp['a'],min(mp['b'],mp['c']));
                ans = ans + 1 + val;
            }
        }
        return ans;
    }
};
