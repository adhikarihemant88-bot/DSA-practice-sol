class Solution {
public:
    int maxScore(vector<int>& cp, int k) {
        int ans = 0;int n = cp.size();
        int l =0;int r = n-1;
        for(int i=0;i<k;i++){
            ans += cp[i];
            l=i;
        }
        int val = ans;
        if(k == n){
            return ans;
        }
        while(l>=0 && r>=0){
            val  = val - cp[l] +cp[r];
            ans = max(ans,val);
            l--;r--;
        }
        return ans;

    }
};
