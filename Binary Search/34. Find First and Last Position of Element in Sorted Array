int checkOccurence(vector<int> A, int B, bool first){
    int low =0;int high = A.size()-1;
    int ans =-1;
    
    while(low<=high) {
        int mid = low + (high-low)/2;
        if(A[mid] == B) {
            ans = mid;
            if(first) {
                high = mid-1;
            }
            else {
                low =mid+1;
            }
        } else if (A[mid]<B) {
            low = mid+1;
        } else {
            high = mid-1;
        }
    }
    return ans;
}

vector<int> searchRange( vector<int> &A, int B) {
    int first = checkOccurence(A,B,true);
    int last = checkOccurence(A,B,false);
    return {first,last};
}

int main() {
  vector<int> A = {5, 7, 7, 8, 8, 10};
  int B = 8;
  vector<int> ans = searchRange(A,B);
}
