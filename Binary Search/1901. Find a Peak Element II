// ref : https://leetcode.com/problems/find-a-peak-element-ii/description/
   class Solution {
public:
    vector<int> findPeakGrid(vector<vector<int>>& mat) {
        int m = mat.size();
        int n = mat[0].size();
        vector<int> xi = {-1,1,0,0};
        vector<int> yi = {0,0,-1,1};
        vector<int> ans;
        for(int i=0;i<m;i++) {
            for(int j=0;j<n;j++){
                int val = mat[i][j];
                int flag = 1;
                for(int p=0;p<4;p++){
                    int x = i + xi[p];
                    int y = j + yi[p];
                    if( x>=0 && x<m &&
                        y>=0 && y<n) {
                            if(val <= mat[x][y]) {
                                flag = 0;
                                break;
                            }
                        }
                }
                if(flag){
                    ans.push_back(i);
                    ans.push_back(j);
                    return ans;
                }
            }
        }
        return ans;

    }
};
