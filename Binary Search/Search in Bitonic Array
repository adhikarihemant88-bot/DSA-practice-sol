Search in Bitonic Array!

#include <bits/stdc++.h>
using namespace std;

int bs(vector<int> &A, int B, int l, int r, bool inc) {
    while (l <= r) {
        int mid = l + (r - l) / 2;

        if (A[mid] == B)
            return mid;

        if (inc) {
            if (A[mid] < B)
                l = mid + 1;
            else
                r = mid - 1;
        } else {
            if (A[mid] < B)
                r = mid - 1;
            else
                l = mid + 1;
        }
    }

    return -1;
}
int findPeak(vector<int> &A) {
    int l = 0, r = A.size() - 1;

    while (l < r) {
        int mid = l + (r - l) / 2;

        if (A[mid] < A[mid + 1]) {
            l = mid + 1;
        } else {
            r = mid;
        } 
    }

    return l;
}
int solve(vector<int> &A, int B) {
    int peak = findPeak(A);

    int ans = bs(A, B, 0, peak, true);
    if (ans != -1)
        return ans;

    return bs(A, B, peak + 1, A.size() - 1, false);
}


int main(){
  vector<int> A = {3, 9, 10, 20, 17, 5, 1};
  int B = 9;
  int ans = solve(A,B);
}
