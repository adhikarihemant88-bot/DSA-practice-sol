#include<bits/stdc++.h>
using namespace std;
class Solution {
public:
    int maxDepth(string s) {
        int depth =0;
        int ans =0;
        for(auto it:s){
            if(it == '('){
                depth++;
            } else if(it == ')') {
                depth--;
            }
            ans = max(ans,depth);
        }
        return ans;
    }
};
