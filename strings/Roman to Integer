class Solution {
public:
    map<char,int> mp= {{'I',1},{'V',5},{'X',10},{'L',50},{'C',100},{'D',500},{'M',1000}};

    int romanToInt(string s) {
        int ans =0;
        int pre = mp[s[0]];
        for(int i=1;i<s.size();i++) {
            int val = mp[s[i]];
            if(val > pre){
                ans -=pre;
            }else {
                ans += pre;
            }
            pre = val;
        }
        if(pre) {
            ans+=pre;
        }
        return ans;

    }
};
